# Variables de entorno — Backend
# Copiar como: cp .env.example .env.development

NODE_ENV=development
PORT=3000

# PostgreSQL — datos transaccionales (incidents, audit)
# Usar "localhost" si la API corre fuera de Docker, "postgres" si corre dentro
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=incidents_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=secret

# MongoDB — eventos y alertas
# Usar "localhost" fuera de Docker, "mongo" dentro
MONGO_URI=mongodb://localhost:27017/events_db

# Redis — DB0: caché de métricas (TTL 30s) | DB1: cola BullMQ
# Usar "localhost" fuera de Docker, "redis" dentro
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_CACHE_DB=0
REDIS_QUEUE_DB=1

# Seguridad
JWT_SECRET=incidentes-coordinadora-jwt-dev-2026
LEGACY_API_KEY=legacy-php-dev-key-2026

# Frontend (Vite) — referencia para docker-compose
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000

# ──────────────────────────────────────────────────────────────────
# Variables de entorno — Backend
#
# Cómo usar este archivo:
#   cp .env.example .env.development
#
# Los valores de abajo YA FUNCIONAN tal cual con el docker-compose.yml
# de este repo (mismos nombres de servicio, mismo usuario, misma db).
# No es necesario cambiar nada para levantar el proyecto en local.
#
# Si vas a desplegar esto en un servidor real (no en tu máquina para
# la prueba técnica), ahí sí cambias POSTGRES_PASSWORD, JWT_SECRET y
# LEGACY_API_KEY por valores propios — eso es lo único que de verdad
# es "secreto" en este archivo.
# ──────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000

# ── PostgreSQL ───────────────────────────────────────────────────
# Guarda incidents + incident_audit (datos transaccionales).
#
# IMPORTANTE: el valor de POSTGRES_HOST cambia según dónde corras la API:
#   - Si corres "npm run start:dev" en tu máquina (fuera de Docker)
#     y solo postgres/mongo/redis están en contenedores → usa "localhost"
#   - Si la API también corre DENTRO de docker-compose (servicio "api")
#     → usa "postgres" (el nombre del servicio en docker-compose.yml)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=incidents_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=secret

# ── MongoDB ──────────────────────────────────────────────────────
# Guarda events + alerts (alto volumen, forma variable).
# Mismo criterio que arriba: "localhost" si la API corre fuera de
# Docker, "mongo" (nombre del servicio) si corre dentro.
MONGO_URI=mongodb://localhost:27017/events_db

# ── Redis ────────────────────────────────────────────────────────
# Una sola instancia, dos responsabilidades separadas por número de DB:
#   DB0 = caché de métricas del dashboard (TTL 30s)
#   DB1 = cola de BullMQ (procesamiento de alertas en background)
# Mismo criterio de host: "localhost" fuera de Docker, "redis" dentro.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_CACHE_DB=0
REDIS_QUEUE_DB=1

# ── Seguridad ────────────────────────────────────────────────────
# JWT_SECRET firma los tokens del dashboard (operadores humanos).
# Para esta prueba técnica uso un valor fijo y lo dejo visible a
# propósito, porque el evaluador necesita poder levantar el proyecto
# sin tener que inventarse un secreto. En un ambiente productivo real
# este valor se generaría con algo como: openssl rand -base64 32
JWT_SECRET=incidentes-coordinadora-jwt-dev-2026

# LEGACY_API_KEY es la llave que usa el script PHP (HU5) para poder
# leer GET /api/incidents sin necesitar un JWT de usuario.
LEGACY_API_KEY=legacy-php-dev-key-2026

# ── Frontend (Vite) ──────────────────────────────────────────────
# Estas dos no las lee el backend, están aquí solo de referencia
# porque docker-compose las inyecta también al servicio "frontend".
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
